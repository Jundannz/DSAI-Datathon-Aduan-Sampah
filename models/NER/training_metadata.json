{
  "task": "named-entity-recognition",
  "language": "id",
  "base_model": "indobenchmark/indobert-base-p2",
  "architecture": "BERT (indobert-base-p2) + WeightedLossTrainer",
  "entities": [
    "LOC"
  ],
  "label2id": {
    "O": 0,
    "B-LOC": 1,
    "I-LOC": 2
  },
  "id2label": {
    "0": "O",
    "1": "B-LOC",
    "2": "I-LOC"
